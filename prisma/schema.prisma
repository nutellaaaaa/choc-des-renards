// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())

  username     String   @unique
  passwordHash String

  firstName    String
  lastName     String

  phone        String

  category     Category

  role         Role     @default(USER)

  accepted     Boolean  @default(false)
  banned       Boolean  @default(false)

  createdAt    DateTime @default(now())

  loginEvents       LoginEvent[]
  matches           Match[]
  notifications     Notification[]
  pouleMembers      PouleMember[]
  phase2GroupMember Phase2GroupMember?
}

model LoginEvent {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  success   Boolean
  message   String?
  createdAt DateTime @default(now())
}

// Chaque match d'un joueur
model Match {
  id                 Int        @id @default(autoincrement())
  userId             Int
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  phase              String
  roundNumber        Int?

  matchDate          DateTime

  opponentFirstName  String
  opponentLastName   String

  note               String?

  // Publication différée : false = en attente de publication, true = visible
  published          Boolean    @default(false)

  // Lien optionnel vers la rencontre spéciale qui a généré ce match
  specialMatchId     Int?
  specialMatch       SpecialMatch? @relation(fields: [specialMatchId], references: [id], onDelete: SetNull)

  sets               MatchSet[]

  createdAt          DateTime   @default(now())
}

// Score de chaque set d'un match (jusqu'à 5 sets)
model MatchSet {
  id             Int   @id @default(autoincrement())
  matchId        Int
  match          Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  setNumber      Int
  playerScore    Int
  opponentScore  Int
}

// Singleton : état actuel du tournoi (toujours id = 1)
model TournamentState {
  id           Int      @id @default(1)
  currentPhase String   @default("PHASE1")
  currentRound Int?
  // Snapshot figé du classement (JSON sérialisé), null = recalcul à la volée
  rankingSnapshot String?
  updatedAt    DateTime @updatedAt
}

// ── Notifications admin → joueur ──────────────────────────────────────────────
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // "message" = notification simple, "special_match" = rencontre spéciale
  type      String   @default("message")

  title     String
  message   String

  // Pour les rencontres spéciales
  opponentName   String?   // Nom affiché de l'adversaire
  startDate      DateTime? // À partir de
  endDate        DateTime? // Avant le
  reason         String?   // Motif

  read      Boolean  @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())
}

// ── Rencontres spéciales (section publique "en cours") ────────────────────────
model SpecialMatch {
  id             Int      @id @default(autoincrement())

  // Les deux joueurs
  player1Id      Int
  player2Id      Int

  // Infos affichées
  startDate      DateTime
  endDate        DateTime
  reason         String
  note           String?

  // false = en cours, true = résultats enregistrés (disparaît de la section publique)
  resolved       Boolean  @default(false)

  createdAt      DateTime @default(now())

  matches        Match[]
}

// ── Poules (Phase 1) ──────────────────────────────────────────────────────────
model Poule {
  id        Int      @id @default(autoincrement())
  name      String
  phase     String   @default("PHASE1")
  createdAt DateTime @default(now())

  members   PouleMember[]
}

model PouleMember {
  id      Int  @id @default(autoincrement())
  pouleId Int
  poule   Poule @relation(fields: [pouleId], references: [id], onDelete: Cascade)
  userId  Int  @unique  // un joueur = une seule poule
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Groupes Phase 2 ───────────────────────────────────────────────────────────
model Phase2Group {
  id        Int      @id @default(autoincrement())
  // "choquants" ou "choques"
  name      String
  createdAt DateTime @default(now())

  members   Phase2GroupMember[]
}

model Phase2GroupMember {
  id      Int  @id @default(autoincrement())
  groupId Int
  group   Phase2Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  Int  @unique
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum Category {
  N
  R
  D
  P
}
