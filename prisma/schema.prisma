// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())

  username     String   @unique
  passwordHash String

  firstName    String
  lastName     String

  phone        String

  category     Category

  role         Role     @default(USER)

  accepted     Boolean  @default(false)
  banned       Boolean  @default(false)

  createdAt    DateTime @default(now())

  loginEvents  LoginEvent[]
  matches      Match[]
}

model LoginEvent {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  success   Boolean
  message   String?
  createdAt DateTime @default(now())
}

// Chaque match d'un joueur
model Match {
  id                 Int        @id @default(autoincrement())
  userId             Int
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Phase du tournoi au moment du match
  // "PHASE1" | "PHASE2" (+ roundNumber pour les rondes suisses)
  phase              String
  roundNumber        Int?       // null pour Phase 1, 1, 2, 3… pour Phase 2

  matchDate          DateTime

  opponentFirstName  String
  opponentLastName   String

  note               String?

  sets               MatchSet[]

  createdAt          DateTime   @default(now())
}

// Score de chaque set d'un match (jusqu'à 5 sets)
model MatchSet {
  id             Int   @id @default(autoincrement())
  matchId        Int
  match          Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  setNumber      Int   // 1 à 5
  playerScore    Int
  opponentScore  Int
}

// Singleton : état actuel du tournoi (toujours id = 1)
model TournamentState {
  id           Int      @id @default(1)
  currentPhase String   @default("PHASE1")
  // Pour Phase 2 : numéro de la ronde courante (null = Phase 1)
  currentRound Int?
  updatedAt    DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum Category {
  N
  R
  D
  P
}
