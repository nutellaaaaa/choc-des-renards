// schema.prisma — Choc des Renards

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Category {
  N
  R
  D
  P
  NC
}

enum Phase {
  PHASE0
  PHASE1
  PHASE2
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String
  category     Category @default(NC)
  role         Role     @default(USER)
  accepted     Boolean  @default(false)
  banned       Boolean  @default(false)
  active       Boolean  @default(true)
  forceLogout  Boolean  @default(false)
  isBot        Boolean  @default(false)
  createdAt    DateTime @default(now())

  matches        Match[]
  pouleMembers   PouleMember[]
  phase2Members  Phase2GroupMember[]
  notifications  Notification[]
  loginEvents    LoginEvent[]
  specialMatches1 SpecialMatch[] @relation("Player1")
  specialMatches2 SpecialMatch[] @relation("Player2")
  plannedMatches1 PlannedMatch[] @relation("PlannedPlayer1")
  plannedMatches2 PlannedMatch[] @relation("PlannedPlayer2")
  faqViews       FaqView[]
  faqVotes       FaqVote[]
  contactMessages ContactMessage[]
  botTasks       BotTask[]
}

model LoginEvent {
  id        Int      @id @default(autoincrement())
  userId    Int
  ip        String?
  userAgent String?
  success   Boolean
  message   String?
  createdAt DateTime @default(now())
  logoutAt  DateTime?
  logoutReason String? // 'manual' | 'inactivity'

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Historique des inscriptions refusées (conservé après suppression du compte)
model RefusedRegistration {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  phone     String
  refusedAt DateTime @default(now())
}

model TournamentState {
  id              Int     @id @default(autoincrement())
  currentPhase    Phase   @default(PHASE0)
  currentRound    Int?
  rankingSnapshot String?
  siteSuspended   Boolean @default(false)
}

model Poule {
  id        Int      @id @default(autoincrement())
  name      String
  phase     Phase    @default(PHASE1)
  createdAt DateTime @default(now())
  members   PouleMember[]
}

model PouleMember {
  id      Int  @id @default(autoincrement())
  pouleId Int
  userId  Int

  poule Poule @relation(fields: [pouleId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pouleId, userId])
}

model Phase2Group {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  members   Phase2GroupMember[]
}

model Phase2GroupMember {
  id      Int @id @default(autoincrement())
  groupId Int
  userId  Int

  group Phase2Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Match {
  id                Int      @id @default(autoincrement())
  userId            Int
  phase             Phase
  roundNumber       Int?
  matchDate         DateTime
  opponentFirstName String
  opponentLastName  String
  note              String?
  published         Boolean  @default(false)
  specialMatchId    Int?
  createdAt         DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets         MatchSet[]
  photos       MatchPhoto[]
  specialMatch SpecialMatch? @relation(fields: [specialMatchId], references: [id])
}

model MatchPhoto {
  id        Int      @id @default(autoincrement())
  matchId   Int
  url       String
  publicId  String?
  caption   String?
  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model MatchSet {
  id            Int @id @default(autoincrement())
  matchId       Int
  setNumber     Int
  playerScore   Int
  opponentScore Int

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model SpecialMatch {
  id        Int      @id @default(autoincrement())
  player1Id Int
  player2Id Int
  startDate DateTime
  endDate   DateTime
  reason    String
  note      String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  player1  User    @relation("Player1", fields: [player1Id], references: [id])
  player2  User    @relation("Player2", fields: [player2Id], references: [id])
  matches  Match[]
}

// Matchs planifiés (à venir, non encore joués)
model PlannedMatch {
  id          Int      @id @default(autoincrement())
  player1Id   Int
  player2Id   Int
  scheduledDate DateTime?
  malus       String?  // enum value or null
  malusTarget Int?     // 1 = player1, 2 = player2
  note        String?
  phase       Phase    @default(PHASE1)
  roundNumber Int?
  createdAt   DateTime @default(now())

  // ── Planification automatique ──
  notifiedAt  DateTime? // horodatage d'envoi de la notification "prochain match" (snapshot figé, non resynchronisé)
  deadlineAt  DateTime? // scheduledDate + cycleLengthDays - deadlineHoursBeforeCycleEnd
  forfeited   Boolean  @default(false) // passé à true par le balayage automatique (forfait 0-0)

  player1 User @relation("PlannedPlayer1", fields: [player1Id], references: [id])
  player2 User @relation("PlannedPlayer2", fields: [player2Id], references: [id])
  notifications Notification[]
}

model Notification {
  id           Int      @id @default(autoincrement())
  userId       Int
  type         String   // 'message' | 'special_match' | 'next_match'
  title        String
  message      String
  opponentName String?
  startDate    DateTime?
  endDate      DateTime?
  reason       String?
  read         Boolean  @default(false)
  readAt       DateTime?
  createdAt    DateTime @default(now())

  plannedMatchId Int?
  plannedMatch   PlannedMatch? @relation(fields: [plannedMatchId], references: [id], onDelete: SetNull)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══════════════════ PLANIFICATION AUTOMATIQUE ═══════════════════

// Un jeu de paramètres par phase (PHASE1 / PHASE2), indépendants. Verrouillés
// (locked = true) dès que la génération a été effectuée ; pour les modifier,
// l'admin doit d'abord supprimer les matchs planifiés de la phase.
model SchedulingSettings {
  id                          Int      @id @default(autoincrement())
  phase                       Phase    @unique
  cycleLengthDays             Int      @default(14)
  deadlineHoursBeforeCycleEnd Int      @default(24)
  periodStart                 DateTime
  periodEnd                   DateTime
  locked                      Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

// Périodes de non-jeu, portée globale à tous les joueurs d'une phase donnée.
model BlackoutPeriod {
  id        Int      @id @default(autoincrement())
  phase     Phase
  label     String
  dateStart DateTime
  dateEnd   DateTime
  createdAt DateTime @default(now())
}

// Console de logs — un seul fil actif par phase, vidé et remplacé à chaque
// nouveau calcul (pas d'historique cumulatif, pas d'onglets datés).
model SchedulingLog {
  id        Int      @id @default(autoincrement())
  phase     Phase
  type      String   // 'info' | 'question' | 'reponse' | 'avertissement' | 'erreur' | 'commande' | 'action'
  message   String
  data      Json?
  createdAt DateTime @default(now())
}

// ═══════════════════ FAQ ═══════════════════

model FaqTopic {
  id             Int      @id @default(autoincrement())
  question       String   // titre du sujet
  order          Int      @default(0)
  viewCount      Int      @default(0)
  usefulCount    Int      @default(0)
  notUsefulCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items FaqItem[]
  views FaqView[]
  votes FaqVote[]
}

model FaqItem {
  id       Int     @id @default(autoincrement())
  topicId  Int
  subtitle String?
  content  String  // texte avec mise en forme basique (gras/italique/listes)
  order    Int     @default(0)

  topic FaqTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

// Historique des consultations (utilisateur + horodatage)
model FaqView {
  id        Int      @id @default(autoincrement())
  topicId   Int
  userId    Int?
  createdAt DateTime @default(now())

  topic FaqTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// Avis "utile" / "pas utile" — un seul vote par utilisateur et par sujet
model FaqVote {
  id        Int      @id @default(autoincrement())
  topicId   Int
  userId    Int
  useful    Boolean
  createdAt DateTime @default(now())

  topic FaqTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
}

// ═══════════════════ FORMULAIRE DE CONTACT ═══════════════════

model ContactMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  nature    String
  subject   String
  message   String
  treated   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══════════════════ BOTS DE TEST ═══════════════════

// File d'actions programmées pour un bot (voir api/admin.js → handleBots).
// Chaque tâche a une échéance réaliste (dueAt) ; elle n'est exécutée que lors
// du prochain "tick" (déclenché à la connexion d'un admin), mais son horodatage
// enregistré (readAt, createdAt de la LoginEvent/Match/etc.) reste celui de
// dueAt afin que l'historique ait l'air naturel même si le traitement réel a
// lieu plus tard.
model BotTask {
  id        Int      @id @default(autoincrement())
  botId     Int
  kind      String   // 'login' | 'logout' | 'read_notification' | 'submit_score' | 'faq_action' | 'contact_message'
  dueAt     DateTime
  payload   Json?
  createdAt DateTime @default(now())

  bot User @relation(fields: [botId], references: [id], onDelete: Cascade)
}
